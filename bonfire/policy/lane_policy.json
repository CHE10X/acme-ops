{
  "agents": {
    "heike": {
      "allowed_lanes": ["interactive"]
    },
    "hendrik": {
      "allowed_lanes": ["interactive", "background"]
    },
    "watchdog": {
      "allowed_lanes": ["system"]
    }
  },
  "lanes": {
    "interactive": {
      "latency_priority": "high",
      "token_limit": "medium",
      "default_model": "claude-sonnet",
      "allowed_models": ["claude-sonnet", "kimi", "gpt4"]
    },
    "background": {
      "latency_priority": "low",
      "token_limit": "strict",
      "default_model": "kimi",
      "allowed_models": ["kimi", "claude-sonnet"],
      "deny_models": ["gpt4", "gpt-4"]
    },
    "system": {
      "latency_priority": "high",
      "token_limit": "unlimited",
      "default_model": "claude-sonnet",
      "allowed_models": ["claude-sonnet", "kimi", "gpt4"]
    }
  },
  "model_alias": {
    "gpt4": ["gpt-4", "gpt4", "gpt-4.1-mini", "gpt4o", "gpt-4o-mini"],
    "claude-sonnet": ["claude-sonnet", "claude-sonnet-4-6", "claude", "sonnet"],
    "kimi": ["kimi", "kimi-k2", "kimi-llama", "openrouter/kimi"]
  }
}
